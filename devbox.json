{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/main/.schema/devbox.schema.json",
  "packages": [
    "go@1.26",
    "buf@1.70",
    "protobuf@34.1",
    "golangci-lint@2.12",
    "gofumpt@0.10",
    "sqlite@3.51",
    "ripgrep@15.1",
    "just@1.51",
    "nodejs@24"
  ],
  "env": {
    "DEVBOX_COREPACK_ENABLED": "true"
  },
  "shell": {
    "init_hook": [
      "export GOBIN=$PWD/bin",
      "export PATH=$GOBIN:$PATH"
    ]
  }
}
