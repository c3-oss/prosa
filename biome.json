{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "extends": ["./node_modules/@c3-oss/config-biome/biome.json"],
  "files": {
    "ignore": ["dist/**", "coverage/**", "node_modules/**", ".devbox/**", "bench/**"]
  },
  "formatter": {
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "semicolons": "always",
      "trailingCommas": "all",
      "lineWidth": 100
    }
  },
  "linter": {
    "rules": {
      "style": {
        "noNonNullAssertion": "off",
        "useImportType": "error",
        "noUnusedTemplateLiteral": "off"
      },
      "suspicious": {
        "noExplicitAny": "warn"
      },
      "complexity": {
        "noForEach": "off"
      }
    }
  }
}
