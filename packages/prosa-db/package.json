{
  "name": "@c3-oss/prosa-db",
  "version": "0.2.1",
  "description": "Shared Drizzle ORM schema for the prosa server (auth, tenancy, sync, projections).",
  "author": "Caian Ertl <hi@caian.org>",
  "license": "MIT",
  "type": "module",
  "private": true,
  "homepage": "https://github.com/c3-oss/prosa#readme",
  "bugs": {
    "url": "https://github.com/c3-oss/prosa/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/c3-oss/prosa.git",
    "directory": "packages/prosa-db"
  },
  "files": ["dist"],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "prosa-dev": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./schema": {
      "prosa-dev": "./src/schema/index.ts",
      "import": "./dist/schema/index.js",
      "types": "./dist/schema/index.d.ts"
    },
    "./testing": {
      "prosa-dev": "./src/testing.ts",
      "import": "./dist/testing.js",
      "types": "./dist/testing.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "clean": "rm -rf dist coverage .turbo"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2"
  },
  "devDependencies": {
    "@c3-oss/config-biome": "^0.3.1",
    "@c3-oss/config-tsup": "^0.2.0",
    "@c3-oss/config-typescript": "^0.1.0",
    "@c3-oss/config-vitest": "^0.3.0",
    "@electric-sql/pglite": "^0.4.5",
    "drizzle-kit": "^0.31.0"
  }
}
