{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "../..",
    "baseUrl": ".",
    "paths": {
      "~/*": ["./src/*"],
      "@c3-oss/prosa-db": ["../../packages/prosa-db/src/index.ts"],
      "@c3-oss/prosa-db/schema": [
        "../../packages/prosa-db/src/schema/index.ts"
      ],
      "@c3-oss/prosa-db/testing": ["../../packages/prosa-db/src/testing.ts"],
      "@c3-oss/prosa-storage": ["../../packages/prosa-storage/src/index.ts"],
      "@c3-oss/prosa-sync": ["../../packages/prosa-sync/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "test/**/*.ts"],
  "exclude": ["dist", "coverage", "node_modules"]
}
