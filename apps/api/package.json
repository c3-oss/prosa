{
  "name": "@c3-oss/prosa-api",
  "version": "0.1.0",
  "description": "Multi-tenant HTTP/tRPC server for prosa sync and remote reads.",
  "author": "Caian Ertl <hi@caian.org>",
  "license": "MIT",
  "type": "module",
  "private": true,
  "homepage": "https://github.com/c3-oss/prosa#readme",
  "bugs": {
    "url": "https://github.com/c3-oss/prosa/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/c3-oss/prosa.git",
    "directory": "apps/api"
  },
  "files": ["dist"],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "prosa-dev": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "prosa-api": "./dist/bin/prosa-api.js"
  },
  "scripts": {
    "dev": "node --conditions=prosa-dev --import @swc-node/register/esm-register src/bin/prosa-api.ts",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "clean": "rm -rf dist coverage .turbo"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.11",
    "@c3-oss/prosa-db": "workspace:^",
    "@c3-oss/prosa-storage": "workspace:^",
    "@c3-oss/prosa-sync": "workspace:^",
    "@trpc/server": "^11.0.0",
    "better-auth": "^1.6.11",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.0.0",
    "@fastify/cors": "^10.0.0",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "zstd-napi": "^0.0.10",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@c3-oss/config-biome": "^0.3.1",
    "@c3-oss/config-tsup": "^0.2.0",
    "@c3-oss/config-typescript": "^0.1.0",
    "@c3-oss/config-vitest": "^0.3.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@electric-sql/pglite": "^0.4.5",
    "@trpc/client": "^11.0.0",
    "drizzle-kit": "^0.31.0"
  }
}
