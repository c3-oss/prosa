{
  "extends": "@c3-oss/config-typescript/lib.json",
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    "jsx": "react-jsx",
    "verbatimModuleSyntax": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "exactOptionalPropertyTypes": false,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "sourceMap": true
  }
}
