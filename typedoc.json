{
  "$schema": "https://typedoc.org/schema.json",
  "name": "prosa API",
  "entryPoints": [
    "src/index.ts",
    "src/mcp/server.ts",
    "src/mcp/tools.ts",
    "src/mcp/guidance.ts"
  ],
  "tsconfig": "tsconfig.json",
  "out": "docs/api",
  "readme": "README.md",
  "includeVersion": true,
  "excludePrivate": true,
  "excludeInternal": true,
  "sort": ["source-order"],
  "navigation": {
    "includeGroups": true,
    "includeCategories": true
  },
  "requiredToBeDocumented": [
    "Variable",
    "Function",
    "Class",
    "Interface",
    "Property",
    "Method",
    "Accessor",
    "TypeAlias"
  ],
  "validation": {
    "notExported": true,
    "invalidLink": true,
    "rewrittenLink": true,
    "notDocumented": true,
    "unusedMergeModuleWith": true
  },
  "treatValidationWarningsAsErrors": true
}
