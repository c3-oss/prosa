{
  "name": "@c3-oss/prosa-workspace",
  "version": "0.0.0",
  "description": "Monorepo for prosa, a CLI and core library for local agent session histories.",
  "author": "Caian Ertl <hi@caian.org>",
  "private": true,
  "license": "MIT",
  "homepage": "https://github.com/c3-oss/prosa#readme",
  "bugs": {
    "url": "https://github.com/c3-oss/prosa/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/c3-oss/prosa.git"
  },
  "packageManager": "pnpm@10.8.1",
  "engines": {
    "node": ">=22.15.1 <27"
  },
  "scripts": {
    "dev": "pnpm --filter @c3-oss/prosa dev",
    "dev:all": "turbo dev --parallel",
    "build": "turbo build",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "format": "biome format --write .",
    "test": "turbo test",
    "test:coverage": "turbo test:coverage",
    "typecheck": "turbo typecheck",
    "docs": "typedoc --options typedoc.json",
    "docs:check": "typedoc --options typedoc.json --emit none",
    "clean": "turbo clean && rm -rf node_modules .turbo coverage docs/api",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish",
    "prepare": "husky",
    "commit": "cz"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@c3-oss/config-biome": "^0.3.1",
    "@c3-oss/config-tsup": "^0.2.0",
    "@c3-oss/config-typescript": "^0.1.0",
    "@c3-oss/config-vitest": "^0.3.0",
    "@changesets/cli": "^2.29.7",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@commitlint/cz-commitlint": "^20.5.3",
    "@swc-node/register": "^1.10.10",
    "@swc/core": "^1.13.5",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "2.1.9",
    "commitizen": "^4.3.1",
    "husky": "^9.1.7",
    "inquirer": "^9.3.8",
    "lint-staged": "^17.0.2",
    "tsup": "^8.5.0",
    "turbo": "^2.5.6",
    "typedoc": "^0.28.19",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "@swc/core",
      "better-sqlite3",
      "esbuild",
      "zstd-napi"
    ],
    "overrides": {
      "fast-uri": "3.1.2",
      "hono": "4.12.18",
      "ip-address": "10.1.1",
      "react": "19.2.5",
      "react-dom": "19.2.5",
      "zod": "^3.25.76"
    }
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,jsonc}": "biome check --write --no-errors-on-unmatched"
  }
}
